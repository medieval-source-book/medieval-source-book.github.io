---
pagination:
  data: collections.editsNeededRedirects
  size: 1
  alias: redirect
permalink: "{{ redirect.permalink }}"
eleventyExcludeFromCollections: true
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>Redirecting...</title>
  <meta http-equiv="refresh" content="0; url={{ redirect.target | safe }}">
  <link rel="canonical" href="{{ redirect.target | safe }}">
</head>
<body>
  <p>Redirecting to <a href="{{ redirect.target | safe }}">{{ redirect.target }}</a>.</p>
</body>
</html>
